{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BrainResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "message",
    "confidence",
    "intent",
    "lead_stage",
    "escalation_reason",
    "memory_summary"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["reply", "escalate", "silent"]
    },
    "message": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "intent": {
      "type": "string"
    },
    "lead_stage": {
      "type": "string"
    },
    "escalation_reason": {
      "type": "string"
    },
    "memory_summary": {
      "type": "string"
    }
  }
}
